{
  "name": "project-task-dashboard",
  "version": "1.0.0",
  "description": "Role-based project, team, and task tracking web app.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "npx prisma db push && node src/server.js",
    "db:migrate": "npx prisma db push",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "postinstall": "npx prisma generate",
    "check": "node --check src/server.js && node --check public/app.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0"
  }
}
